DATABASE_URL=postgres://user:password@localhost:5432/code_architect
SESSION_SECRET=change-me
PORT=5000
# Set true only when your app is behind HTTPS (reverse proxy/TLS)
SESSION_COOKIE_SECURE=false

# SMS OTP provider:
# - textbelt: free tier available using key "textbelt" (limited)
# - android_gateway: open-source/self-hosted Android SMS gateway endpoint
# - webhook: custom HTTP endpoint
# - console: no real SMS, logs OTP on server
SMS_PROVIDER=textbelt

# textbelt settings
# Use "textbelt" for free daily quota, or your paid key
SMS_TEXTBELT_KEY=textbelt

# android_gateway settings (open-source/self-hosted)
# Example: https://your-gateway.example.com/api/messages
SMS_ANDROID_GATEWAY_URL=
SMS_ANDROID_GATEWAY_TOKEN=

# webhook settings
SMS_WEBHOOK_URL=
